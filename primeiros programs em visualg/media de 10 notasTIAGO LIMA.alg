algoritmo "Exercicios avaliacao"
// Funçăo : Exercicio numero 4
// Autores : Tiago Lima
// Data : 28/06/2015
// Seçăo de Declaraçőes
var
y,z: real
numero,x:inteiro
s:caracter
inicio
// Seçăo de Comandos
s<-"s"
enquanto s="s" faca
Escreval ("Programa que faz media de 10 notas") // Escreval= escrever em linhas diferentes
  para numero de 1 ate 10 faca
leia(X)
 y<-y+x

fimpara
z<-y/x
escreval("Media= ",z)
escreval (" Quer continuar? S ou N")
Leia (s)
fimenquanto

fimalgoritmo


