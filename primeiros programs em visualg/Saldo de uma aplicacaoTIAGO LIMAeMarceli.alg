algoritmo "Exercicios avaliacao"
// Funēćo : Exemplo de Aula
// Autores : Tiago Lima e Marceli
// Data : 28/05/2015
// Seēćo de Declaraēões
var
saldo,aplicacao: NUMERICO
inicio
// Seēćo de Comandos


Escreva ("Digite o saldo: ") // Escreva = escreve na mesma linha
Leia (saldo)
aplicacao<-saldo+(saldo*0.08) // aplicacao de 8 porcento
Escreval ("A aplicacao e:  ", aplicacao   )
Escreva ("Autor TIAGO LIMA e Marceli")
fimalgoritmo
