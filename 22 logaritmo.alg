algoritmo "semnome"
// Função :
// Autor :
// Data : 03/08/2015
// Seção de Declarações 
var
numeros,loga:numerico
numero:inteiro
inicio
// Seção de Comandos 
escreval("logaritmo")
para numero de 1 ate 8 faca
  escreval("Digite um numero")
  leia(numero)
   se (numero>0) entao
   loga<- log(numero)
   escreval("",loga)
   fimse
      fimpara
fimalgoritmo
